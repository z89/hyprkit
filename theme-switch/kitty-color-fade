#!/usr/bin/env python3
"""Smoothly fade kitty terminal colors from old to new over a duration."""

import os
import re
import subprocess
import sys
import time
from glob import glob

STEPS = 30
DURATION = 1.0  # seconds
DELAY = 0.4     # seconds before starting fade (sync with swww reveal)

# Color keys that kitty @ set-colors accepts
COLOR_KEYS = {
    "foreground", "background", "cursor", "cursor_text_color",
    "selection_foreground", "selection_background", "url_color",
    "active_tab_foreground", "active_tab_background",
    "inactive_tab_foreground", "inactive_tab_background",
    *{f"color{i}" for i in range(16)},
}


def parse_colors(path):
    """Parse a kitty colors.conf file into {key: (r, g, b)} dict."""
    colors = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            match = re.match(r"^(\S+)\s+(#[0-9a-fA-F]{6})", line)
            if match:
                key, hexval = match.group(1), match.group(2)
                if key in COLOR_KEYS:
                    r = int(hexval[1:3], 16)
                    g = int(hexval[3:5], 16)
                    b = int(hexval[5:7], 16)
                    colors[key] = (r, g, b)
    return colors


def lerp_color(c1, c2, t):
    """Linear interpolation between two RGB tuples."""
    return tuple(int(a + (b - a) * t) for a, b in zip(c1, c2))


def rgb_to_hex(rgb):
    return f"#{rgb[0]:02x}{rgb[1]:02x}{rgb[2]:02x}"


def get_kitty_sockets():
    """Find all kitty remote control sockets."""
    return glob("/tmp/kitty-*")


def set_colors(sockets, color_args):
    """Push colors to all kitty instances."""
    for sock in sockets:
        try:
            subprocess.Popen(
                ["kitty", "@", "--to", f"unix:{sock}", "set-colors"] + color_args,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except OSError:
            pass


def main():
    if len(sys.argv) != 3:
        print(f"Usage: {sys.argv[0]} <old-colors.conf> <new-colors.conf>", file=sys.stderr)
        sys.exit(1)

    old_path, new_path = sys.argv[1], sys.argv[2]
    old_colors = parse_colors(old_path)
    new_colors = parse_colors(new_path)

    # Only interpolate keys present in both
    common_keys = sorted(old_colors.keys() & new_colors.keys())
    if not common_keys:
        sys.exit(0)

    sockets = get_kitty_sockets()
    if not sockets:
        sys.exit(0)

    time.sleep(DELAY)

    step_delay = DURATION / STEPS
    for step in range(1, STEPS + 1):
        t = step / STEPS
        # Ease-in-out cubic
        t = 4 * t * t * t if t < 0.5 else 1 - (-2 * t + 2) ** 3 / 2
        color_args = []
        for key in common_keys:
            blended = lerp_color(old_colors[key], new_colors[key], t)
            color_args.append(f"{key}={rgb_to_hex(blended)}")
        set_colors(sockets, color_args)
        if step < STEPS:
            time.sleep(step_delay)


if __name__ == "__main__":
    main()
